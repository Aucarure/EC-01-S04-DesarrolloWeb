<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Nombre y Email</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Segoe UI', sans-serif; background: #0f1117; color: #e2e8f0; min-height: 100vh; }
    nav { background: #1a1d27; border-bottom: 1px solid #2d3148; padding: 0 2rem; display: flex; align-items: center; gap: 2rem; height: 60px; }
    nav .logo { font-size: 18px; font-weight: 700; color: #7c6af7; }
    nav a { color: #94a3b8; text-decoration: none; font-size: 14px; font-weight: 500; padding: 6px 12px; border-radius: 6px; transition: all 0.2s; }
    nav a:hover, nav a.active { color: #e2e8f0; background: #2d3148; }
    .container { max-width: 1000px; margin: 0 auto; padding: 2rem; }
    h1 { font-size: 24px; font-weight: 700; color: #f1f5f9; margin-bottom: 0.25rem; }
    .subtitle { color: #64748b; font-size: 14px; margin-bottom: 2rem; }
    .info-box { background: #1a2535; border: 1px solid #1e3a5f; border-radius: 10px; padding: 12px 16px; margin-bottom: 1.5rem; font-size: 13px; color: #60a5fa; }
    .card { background: #1a1d27; border: 1px solid #2d3148; border-radius: 12px; overflow: hidden; }
    table { width: 100%; border-collapse: collapse; }
    th { text-align: left; font-size: 11px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px; padding: 10px 14px; border-bottom: 1px solid #2d3148; }
    td { padding: 14px; border-bottom: 1px solid #1e2235; font-size: 14px; color: #cbd5e1; }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: #1e2235; }
    .num { color: #7c6af7; font-weight: 600; font-size: 13px; }
    .email-badge { display: inline-block; background: #1a1f35; color: #818cf8; border: 1px solid #2d3360; border-radius: 6px; padding: 3px 10px; font-size: 13px; font-family: monospace; }
    .avatar { width: 32px; height: 32px; border-radius: 50%; background: #2d2060; color: #c4b5fd; display: inline-flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700; margin-right: 10px; vertical-align: middle; }
  </style>
</head>
<body>
  <nav>
    <span class="logo">&#9670; DevPanel</span>
    <a href="/items">Productos</a>
    <a href="/usuarios">Usuarios</a>
    <a href="/usuarios/transformar" class="active">Nombre y Email</a>
  </nav>

  <div class="container">
    <h1>Datos Transformados</h1>
    <p class="subtitle">Vista reducida: solo nombre y email de cada usuario</p>

    <div class="info-box">
      Datos procesados desde la API externa — se filtraron todos los campos excepto nombre y email
    </div>

    <div class="card">
      <table>
        <thead>
          <tr>
            <th>#</th>
            <th>Nombre</th>
            <th>Email</th>
          </tr>
        </thead>
        <tbody>
          <% transformados.forEach((u, i) => { %>
            <% const initials = u.nombre.split(' ').slice(0,2).map(n => n[0]).join(''); %>
            <tr>
              <td class="num"><%= i + 1 %></td>
              <td>
                <span class="avatar"><%= initials %></span>
                <span style="font-weight:500; color:#e2e8f0"><%= u.nombre %></span>
              </td>
              <td><span class="email-badge"><%= u.email %></span></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</body>
</html>
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Gestión de Productos</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Segoe UI', sans-serif; background: #0f1117; color: #e2e8f0; min-height: 100vh; }
    nav { background: #1a1d27; border-bottom: 1px solid #2d3148; padding: 0 2rem; display: flex; align-items: center; gap: 2rem; height: 60px; }
    nav .logo { font-size: 18px; font-weight: 700; color: #7c6af7; }
    nav a { color: #94a3b8; text-decoration: none; font-size: 14px; font-weight: 500; padding: 6px 12px; border-radius: 6px; transition: all 0.2s; }
    nav a:hover, nav a.active { color: #e2e8f0; background: #2d3148; }
    .container { max-width: 1000px; margin: 0 auto; padding: 2rem; }
    h1 { font-size: 24px; font-weight: 700; color: #f1f5f9; margin-bottom: 0.25rem; }
    .subtitle { color: #64748b; font-size: 14px; margin-bottom: 2rem; }
    .card { background: #1a1d27; border: 1px solid #2d3148; border-radius: 12px; padding: 1.5rem; margin-bottom: 1.5rem; }
    .card h2 { font-size: 12px; font-weight: 600; color: #c4b5fd; margin-bottom: 1rem; text-transform: uppercase; letter-spacing: 0.5px; }
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    label { display: block; font-size: 12px; color: #94a3b8; margin-bottom: 6px; font-weight: 500; }
    input, textarea { width: 100%; background: #0f1117; border: 1px solid #2d3148; border-radius: 8px; padding: 10px 14px; color: #e2e8f0; font-size: 14px; font-family: inherit; transition: border 0.2s; }
    input:focus, textarea:focus { outline: none; border-color: #7c6af7; }
    textarea { resize: vertical; min-height: 80px; }
    .btn { padding: 10px 20px; border: none; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; transition: all 0.2s; }
    .btn-primary { background: #7c6af7; color: white; width: 100%; margin-top: 18px; }
    .btn-primary:hover { background: #6d5ce6; }
    .btn-danger { background: #2d1f1f; color: #f87171; border: 1px solid #3d2626; font-size: 12px; padding: 6px 12px; border-radius: 6px; cursor: pointer; }
    .btn-warning { background: #2d2a1a; color: #fbbf24; border: 1px solid #3d3620; font-size: 12px; padding: 6px 12px; border-radius: 6px; cursor: pointer; }
    table { width: 100%; border-collapse: collapse; }
    th { text-align: left; font-size: 11px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px; padding: 10px 14px; border-bottom: 1px solid #2d3148; }
    td { padding: 14px; border-bottom: 1px solid #1e2235; font-size: 14px; color: #cbd5e1; }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: #1e2235; }
    .badge { display: inline-block; background: #1e2235; color: #7c6af7; border: 1px solid #2d3148; border-radius: 20px; padding: 2px 10px; font-size: 12px; font-weight: 600; }
    .actions { display: flex; gap: 8px; }
    .empty { text-align: center; padding: 3rem; color: #475569; font-size: 14px; }
    .modal-bg { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.7); z-index: 100; align-items: center; justify-content: center; }
    .modal-bg.open { display: flex; }
    .modal { background: #1a1d27; border: 1px solid #2d3148; border-radius: 16px; padding: 2rem; width: 100%; max-width: 480px; }
    .modal h3 { font-size: 18px; color: #f1f5f9; margin-bottom: 1.5rem; }
    .modal-footer { display: flex; gap: 10px; margin-top: 1.5rem; justify-content: flex-end; }
    .btn-secondary { background: #2d3148; color: #94a3b8; border: none; padding: 10px 20px; border-radius: 8px; font-size: 14px; cursor: pointer; }
    .toast { position: fixed; bottom: 2rem; right: 2rem; background: #1a1d27; border: 1px solid #2d3148; border-left: 3px solid #7c6af7; border-radius: 8px; padding: 12px 20px; font-size: 14px; color: #e2e8f0; z-index: 200; opacity: 0; transition: opacity 0.3s; pointer-events: none; }
    .toast.show { opacity: 1; }
  </style>
</head>
<body>
  <nav>
    <span class="logo">&#9670; DevPanel</span>
    <a href="/items" class="active">Productos</a>
    <a href="/usuarios">Usuarios</a>
    <a href="/usuarios/transformar">Nombre y Email</a>
  </nav>

  <div class="container">
    <h1>Gestión de Productos</h1>
    <p class="subtitle">Administra tu inventario de productos</p>

    <div class="card">
      <h2>Nuevo Producto</h2>
      <form action="/items" method="POST">
        <div class="form-grid">
          <div>
            <label>Nombre</label>
            <input type="text" name="nombre" placeholder="Ej: Laptop Dell XPS" required>
          </div>
          <div>
            <label>&nbsp;</label>
            <button class="btn btn-primary" type="submit">+ Agregar Producto</button>
          </div>
          <div style="grid-column: 1 / -1">
            <label>Descripción</label>
            <textarea name="descripcion" placeholder="Describe el producto..." required></textarea>
          </div>
        </div>
      </form>
    </div>

    <div class="card" style="padding: 0; overflow: hidden;">
      <table>
        <thead>
          <tr>
            <th>ID</th>
            <th>Nombre</th>
            <th>Descripción</th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% if (items.length === 0) { %>
            <tr><td colspan="4" class="empty">No hay productos registrados aún</td></tr>
          <% } else { %>
            <% items.forEach(item => { %>
              <tr>
                <td><span class="badge">#<%= item.id %></span></td>
                <td style="font-weight:500; color:#e2e8f0"><%= item.nombre %></td>
                <td><%= item.descripcion %></td>
                <td><div class="actions">
                  <button class="btn-warning" onclick="abrirEditar(<%= item.id %>,'<%= item.nombre %>','<%= item.descripcion %>')">Editar</button>
                  <button class="btn-danger" onclick="eliminar(<%= item.id %>)">Eliminar</button>
                </div></td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="modal-bg" id="modal">
    <div class="modal">
      <h3>Editar Producto</h3>
      <label>Nombre</label>
      <input type="text" id="editNombre" style="margin-bottom:1rem">
      <label>Descripción</label>
      <textarea id="editDescripcion"></textarea>
      <div class="modal-footer">
        <button class="btn-secondary" onclick="cerrarModal()">Cancelar</button>
        <button class="btn btn-primary" style="width:auto" onclick="guardarEdicion()">Guardar Cambios</button>
      </div>
    </div>
  </div>

  <div class="toast" id="toast"></div>

  <script>
    let editandoId = null;

    function showToast(msg) {
      const t = document.getElementById('toast');
      t.textContent = msg;
      t.classList.add('show');
      setTimeout(() => t.classList.remove('show'), 2500);
    }

    function abrirEditar(id, nombre, descripcion) {
      editandoId = id;
      document.getElementById('editNombre').value = nombre;
      document.getElementById('editDescripcion').value = descripcion;
      document.getElementById('modal').classList.add('open');
    }

    function cerrarModal() {
      document.getElementById('modal').classList.remove('open');
      editandoId = null;
    }

    async function guardarEdicion() {
      const nombre = document.getElementById('editNombre').value.trim();
      const descripcion = document.getElementById('editDescripcion').value.trim();
      if (!nombre || !descripcion) return showToast('Completa todos los campos');
      await fetch('/items/' + editandoId, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ nombre, descripcion })
      });
      cerrarModal();
      location.reload();
    }

    async function eliminar(id) {
      if (confirm('¿Eliminar este producto?')) {
        await fetch('/items/' + id, { method: 'DELETE' });
        location.reload();
      }
    }
  </script>
</body>
</html>